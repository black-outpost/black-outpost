rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read, write: if request.auth.uid == uid;
      allow read, write: if isAdmin();
    }

    match /characters/{charId} {
      allow read: if request.auth.uid != null;
      allow update: if request.auth.uid == resource.data.userId &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['unlockedNodes', 'blockedNodes', 'stats', 'ndr', 'pdr', 'pinnedPassiveIds']);
      allow read, write: if isAdmin();
    }

    match /skillTrees/{treeId} {
      allow read: if request.auth.uid != null;
      allow write: if isAdmin();
    }

    match /items/{itemId} {
      allow read: if request.auth.uid != null;
      allow write: if isAdmin();
    }
    match /itemBank/{itemId} {
      allow read: if request.auth.uid != null;
      allow write: if isAdmin();
    }
    match /techniques/{techId} {
      allow read: if request.auth.uid != null;
      allow write: if isAdmin();
    }
    match /techniqueBank/{techId} {
      allow read: if request.auth.uid != null;
      allow write: if isAdmin();
    }
    match /positions/{posId} {
      allow read: if request.auth.uid != null;
      allow write: if isAdmin();
    }
    match /equipmentTypes/{id} {
      allow read: if request.auth.uid != null;
      allow write: if isAdmin();
    }
    match /characterTags/{tagId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /adminTasks/{taskId} {
      allow read, write: if isAdmin();
      // Gracz może tworzyć taski (np. zakup węzła z tagiem admin_action)
      allow create: if request.auth != null;
    }

    // Player items — gracz może equip/unequip swoje itemy
    match /characters/{charId}/items/{itemId} {
      allow read: if request.auth.uid != null;
      // Gracz może update tylko pole "equipped" na swoich itemach
      allow update: if request.auth.uid != null &&
        get(/databases/$(database)/documents/characters/$(charId)).data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['equipped']);
      allow write: if isAdmin();
    }

    match /characters/{charId}/techniques/{techId} {
      allow read: if request.auth.uid != null;
      allow write: if isAdmin();
    }

    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false; // logi są niemodyfikowalne
    }

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}
